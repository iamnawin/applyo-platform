# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google Gemini (default provider for text + embeddings)
GOOGLE_AI_API_KEY=your-gemini-api-key

# OpenAI (optional fallback for text tasks)
OPENAI_API_KEY=sk-...

# Groq (optional fallback for text tasks)
GROQ_API_KEY=gsk_...

# AI Provider Order
# Preferred config: ordered fallback chains
AI_TEXT_PROVIDER_ORDER=gemini,openai,groq
AI_EMBEDDING_PROVIDER_ORDER=gemini

# Backward-compatible single-provider shorthands
AI_TEXT_PROVIDER=gemini
AI_EMBEDDING_PROVIDER=gemini

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Automation (Remote Browser via Browserbase/browserless.io)
# Format: wss://connect.browserbase.com?apiKey=YOUR_API_KEY
BROWSER_WS_ENDPOINT=

# Search (Job Discovery via Serper.dev)
SERPER_API_KEY=
